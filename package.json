{
  "name": "entrepreneurship-nexus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "local:start": "bash scripts/start-local-dev.sh",
