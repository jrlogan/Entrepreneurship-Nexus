    "simulate:inbound-email": "node scripts/simulate-inbound-email.mjs",
    "simulate:create-auth-user": "node scripts/create-emulator-user.mjs",
    "simulate:seed-test-accounts": "node scripts/seed-test-accounts.mjs",
    "simulate:postmark-inbound": "node scripts/simulate-postmark-inbound.mjs",
    "simulate:local-email-tests": "node scripts/run-local-email-tests.mjs",
    "simulate:preview-local-notices": "node scripts/preview-local-notices.mjs",
    "simulate:export-email-previews": "node scripts/export-email-previews.mjs",
    "simulate:full-invite-flow": "node scripts/simulate-full-invite-flow.mjs",
    "staging:seed-mail-test": "node scripts/seed-staging-mail-test.mjs",
