
# -------------------------------------------------------------------
# PUBLIC REPO CONFIGURATION TEMPLATE
# Copy this file to '.env' and fill in your real values.
# DO NOT commit the '.env' file to GitHub.
# -------------------------------------------------------------------

# Set to 'false' for Firebase-backed local/dev work, 'true' to use in-memory mock data
VITE_DEMO_MODE=true

# The URL of your backend API (if DEMO_MODE is false)
VITE_API_URL=https://api.yourservice.com

# Optional integration key for local experiments.
# Leave blank unless you are testing an integration that requires it.
VITE_INTEGRATION_KEY=

# Feature Flags
VITE_ENABLE_EMAILS=false

# Firebase Auth / Firestore / Functions
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=

# Local Firebase Emulator Suite
# For local auth/testing, set:
# VITE_DEMO_MODE=false
# VITE_USE_FIREBASE_EMULATORS=true
VITE_USE_FIREBASE_EMULATORS=false
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_AUTH_EMULATOR_PORT=59099
VITE_FIRESTORE_EMULATOR_PORT=58080
VITE_FUNCTIONS_EMULATOR_PORT=55001

# Local webhook testing helpers
POSTMARK_INBOUND_WEBHOOK_SECRET=

# Firebase Functions runtime env or secret values
# Do not put these in the frontend .env for production hosting.
APP_BASE_URL=
POSTMARK_INBOUND_ALLOWED_RECIPIENTS=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound
BOOTSTRAP_PLATFORM_ADMIN_SECRET=

# Safety switch for local-only helper endpoints.
# Leave unset in production. Set true only in emulator/dev projects.
ALLOW_LOCAL_ONLY_FUNCTIONS=false
