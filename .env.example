
# -------------------------------------------------------------------
# PUBLIC REPO CONFIGURATION TEMPLATE
# Copy this file to '.env' and fill in your real values.
# DO NOT commit the '.env' file to GitHub.
# -------------------------------------------------------------------

# Set to 'false' to connect to a real backend, 'true' to use in-memory mock data
VITE_DEMO_MODE=true

# The URL of your backend API (if DEMO_MODE is false)
VITE_API_URL=https://api.yourservice.com

# Your actual API Key for backend communication
VITE_INTEGRATION_KEY=sk_live_xyz...

# Feature Flags
VITE_ENABLE_EMAILS=false
