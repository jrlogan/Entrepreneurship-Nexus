rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(personId) {
      return isAuthenticated() && request.auth.uid == personId;
    }

    function personDoc() {
      return get(/databases/$(database)/documents/people/$(request.auth.uid));
    }

    function hasPersonDoc() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/people/$(request.auth.uid));
    }

    function currentSystemRole() {
      return hasPersonDoc() ? personDoc().data.system_role : null;
    }

    // organization_id is the canonical field; primary_organization_id is the legacy alias.
    // Both are written by createTestAccount. Check organization_id first, fall back to primary.
    function currentOrgId() {
      return hasPersonDoc() ? (
        personDoc().data.organization_id != '' ?
          personDoc().data.organization_id :
          personDoc().data.primary_organization_id
      ) : null;
    }

    function isPlatformAdmin() {
      return hasPersonDoc() && personDoc().data.system_role == 'platform_admin';
    }

    function isEcosystemManager() {
      return hasPersonDoc() && personDoc().data.system_role == 'ecosystem_manager';
    }

    function isNetworkAdmin() {
      return isPlatformAdmin() || isEcosystemManager();
    }

    function isEsoOperator() {
      return hasPersonDoc() && (
        personDoc().data.system_role == 'eso_admin' ||
        personDoc().data.system_role == 'eso_staff' ||
        personDoc().data.system_role == 'eso_coach'
      );
    }

    function isReceivingOrgMember(referral) {
      return isEsoOperator() &&
        currentOrgId() != null &&
        referral.receiving_org_id == currentOrgId();
    }

    function isReferringOrgMember(referral) {
      return isEsoOperator() &&
        currentOrgId() != null &&
        referral.referring_org_id == currentOrgId();
    }

    function isSubjectOrgMember(referral) {
      return hasPersonDoc() &&
        currentOrgId() != null &&
        referral.subject_org_id == currentOrgId();
    }

    function canCreateReferral() {
      return isNetworkAdmin() || (
        hasPersonDoc() &&
        currentOrgId() != null &&
        (
          request.resource.data.referring_org_id == currentOrgId() ||
          request.resource.data.subject_org_id == currentOrgId()
        )
      );
    }

    function canManageReferral(referral) {
      return isNetworkAdmin() ||
        isReceivingOrgMember(referral) ||
        isReferringOrgMember(referral) ||
        isSubjectOrgMember(referral);
    }

    function isOwnAccountRequest(requestId) {
      return isAuthenticated() && request.auth.uid == requestId;
    }

    // Fields on a Person document that a user cannot modify on themselves.
    // Only platform admins / ecosystem managers can change these. Self-update
    // of any of these would allow privilege escalation or org-hopping.
    function personPrivilegedFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'system_role',
        'organization_id',
        'primary_organization_id',
        'ecosystem_id',
        'auth_uid',
        'memberships',
        'secondary_profile'
      ]);
    }

    match /people/{personId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.auth_uid == request.auth.uid;
      allow update: if isNetworkAdmin() || (
        isSelf(personId) && !personPrivilegedFieldsChanged()
      );
      allow delete: if isPlatformAdmin();
    }

    match /person_memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPlatformAdmin();
    }

    match /invites/{inviteId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    match /account_requests/{requestId} {
      allow read: if isPlatformAdmin() || isOwnAccountRequest(requestId);
      allow create: if isOwnAccountRequest(requestId) &&
        request.resource.data.auth_uid == request.auth.uid;
      allow update: if isPlatformAdmin() || isOwnAccountRequest(requestId);
      allow delete: if isPlatformAdmin();
    }

    // ESO operators may only update organizations where their own org is
    // listed in managed_by_ids, and may not change managed_by_ids themselves
    // (otherwise they could grant themselves management of any other org).
    function canEsoOperatorUpdateOrg() {
      return isEsoOperator() &&
        currentOrgId() != null &&
        (currentOrgId() in resource.data.managed_by_ids) &&
        request.resource.data.managed_by_ids == resource.data.managed_by_ids;
    }

    match /organizations/{organizationId} {
      allow read: if isAuthenticated();
      // Create stays permissive for now; the privilege-escalation bug was on
      // update (ESO operator at Org A could modify any other org). Creating
      // a fresh org doesn't grant retroactive control over others.
      allow create: if isPlatformAdmin() || isEsoOperator();
      allow update: if isPlatformAdmin() || canEsoOperatorUpdateOrg();
      allow delete: if isPlatformAdmin();
    }

    match /network_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create, update: if isPlatformAdmin() || isSelf(profileId);
      allow delete: if isPlatformAdmin();
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated();
      allow create: if canCreateReferral();
      allow update, delete: if canManageReferral(resource.data);
    }

    match /interactions/{interactionId} {
      allow read: if isAuthenticated();
      allow create, update: if isPlatformAdmin() || isEsoOperator();
      allow delete: if isPlatformAdmin();
    }

    match /pipelines/{pipelineId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    match /initiatives/{initiativeId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin() || isEsoOperator();
    }

    match /grants/{grantId} {
      allow read: if isAuthenticated();
      allow create, update: if isNetworkAdmin() || isEsoOperator();
      allow delete: if isPlatformAdmin();
    }

    match /monitored_grant_sources/{sourceId} {
      allow read: if isAuthenticated();
      allow create, update: if isNetworkAdmin() || isEsoOperator();
      allow delete: if isPlatformAdmin();
    }

    match /grant_drafts/{draftId} {
      allow read: if isAuthenticated();
      allow create, update: if isNetworkAdmin() || isEsoOperator();
      allow delete: if isPlatformAdmin();
    }

    match /participations/{participationId} {
      allow read: if isAuthenticated();
      allow create, update: if isPlatformAdmin() || isEsoOperator();
      allow delete: if isPlatformAdmin();
    }

    match /inbound_routes/{routeId} {
      allow read: if isAuthenticated();
      allow write: if isNetworkAdmin();
    }

    match /authorized_sender_domains/{domainId} {
      allow read: if isAuthenticated();
      allow write: if isNetworkAdmin() || isEsoOperator();
    }

    match /consent_policies/{policyId} {
      allow read: if isAuthenticated();
      allow create: if isNetworkAdmin() || (
        hasPersonDoc() &&
        currentOrgId() != null &&
        request.resource.data.resource_id == currentOrgId()
      );
      allow update: if isNetworkAdmin() || (
        hasPersonDoc() &&
        currentOrgId() != null &&
        resource.data.resource_id == currentOrgId() &&
        request.resource.data.resource_id == resource.data.resource_id
      );
      allow delete: if false;
    }

    match /consent_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isNetworkAdmin() || (
        hasPersonDoc() &&
        currentOrgId() != null &&
        request.resource.data.resource_id == currentOrgId()
      );
      allow update, delete: if false;
    }

    match /consent_requests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /organization_aliases/{aliasId} {
      allow read: if isAuthenticated();
      allow create, update: if isPlatformAdmin() || isEsoOperator();
      allow delete: if isPlatformAdmin();
    }

    match /inbound_messages/{messageId} {
      allow read: if isNetworkAdmin();
      allow write: if false;
    }

    // consent_tokens: written only by Cloud Functions (partnerUpsertPerson / consentAccept).
    // No client-side read/write — the raw token is in the email link only.
    match /consent_tokens/{tokenHash} {
      allow read, write: if false;
    }

    // oidc_providers: written by partnerRegisterOidcProvider Cloud Function.
    // ESO operators can read their own org's provider; client_secret is never
    // returned by the oidcGetProviders HTTP function (server-side only).
    match /oidc_providers/{providerId} {
      allow read: if isEsoOperator() || isNetworkAdmin();
      allow write: if false;
    }

    match /inbound_parse_results/{resultId} {
      allow read: if isNetworkAdmin();
      allow write: if false;
    }

    match /notice_queue/{noticeId} {
      allow read: if isNetworkAdmin();
      allow write: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isPlatformAdmin();
      allow update: if isPlatformAdmin();
      allow delete: if false;
    }

    // Agreement acceptances — each user can create and read their own records only.
    // Documents are immutable once written (no update/delete).
    match /agreement_acceptances/{acceptanceId} {
      allow read: if isAuthenticated() && (
        resource.data.auth_uid == request.auth.uid || isPlatformAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.auth_uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Partner API lookup index — written exclusively by Cloud Functions (Admin SDK).
    // No client-side access needed; deny all to prevent enumeration.
    match /external_ref_index/{indexId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
